---
import sideDiscussing from "../assets/images/side-view-people-discussing-work.jpg";
import groupLaptops from "../assets/images/group-people-with-laptops.jpg";
import groupAnalyzing from "../assets/images/group-creative-people-analyzing-result-work.jpg";

const panels = [
	{
		title: "Detecta riesgo antes de que escale",
		body: "Anticipa problemas de talento con semanas de margen para actuar.",
		image: sideDiscussing.src,
		imageAlt: "Personas en reunión discutiendo trabajo en la oficina",
	},
	{
		title: "Visibilidad del potencial real",
		body: "Conoce el potencial de tu equipo y activa la movilidad interna con criterio.",
		image: groupLaptops.src,
		imageAlt: "Equipo trabajando juntos con portátiles alrededor de una mesa",
	},
	{
		title: "Decisiones basadas en datos",
		body: "Cada decisión sobre personas, documentada y fundamentada en datos reales.",
		image: groupAnalyzing.src,
		imageAlt: "Personas analizando resultados y documentos en un espacio creativo",
	},
];

const panelsJson = JSON.stringify(panels);
---

<section
	class="w-full max-w-7xl mx-auto px-4 py-8 md:py-16"
	aria-labelledby="just-ask-klya-heading"
	data-just-ask-klya
	data-panels-json={panelsJson}
	id="usecases"
>
	<div class="mx-auto flex max-w-3xl flex-col items-center justify-center gap-2 text-center md:gap-3">
		<p class="text-sm font-medium text-emerald-600">Casos de uso</p>
		<h2 id="just-ask-klya-heading" class="text-3xl text-slate-900 md:text-4xl">
			Para los que lideran equipos en movimiento.
		</h2>
		<p class="mt-3 text-base text-slate-500 md:mt-4 md:text-xl">
			Talio está diseñado para managers que toman decisiones críticas
			<br>
			sobre personas en contextos de crecimiento o cambio.
		</p>
	</div>

	<div class="mt-12 md:mt-16 grid grid-cols-1 gap-10 md:grid-cols-3 md:items-center md:gap-12 lg:gap-16">
		<div class="flex flex-col gap-10 md:col-span-1 md:gap-20">
			<div class="relative flex flex-col gap-8 md:gap-12" data-just-ask-items>
				<div
					data-just-ask-indicator
					class="pointer-events-none absolute left-0 z-10 w-0.5 rounded-full bg-emerald-600 will-change-[top,height]"
					aria-hidden="true"
				/>
				{
					panels.map((panel, i) => (
						<button
							type="button"
							data-just-ask-item
							data-index={i}
							aria-current={i === 0 ? "true" : "false"}
							class:list={[
								"relative z-0 flex cursor-pointer flex-col gap-2 rounded-r-lg pl-4 text-left transition-opacity duration-300 ease-out",
								i === 0 ? "opacity-100" : "opacity-50",
							]}
						>
							<h3 class="text-lg text-slate-800">{panel.title}</h3>
							<p class="text-base text-slate-500">{panel.body}</p>
						</button>
					))
				}
			</div>
			<a
				href="mailto:hello@acalvet.com"
				class="self-start text-base font-medium text-white bg-emerald-600 rounded-full px-6 py-3 hover:bg-emerald-500"
			>
				Solicitar demo
			</a>
		</div>

		<div class="md:col-span-2">
			<div
				class="relative aspect-4/3 w-full overflow-hidden rounded-2xl bg-slate-100 ring-1 ring-slate-900/5"
				data-just-ask-image-stack
			>
				<img
					data-just-ask-layer="0"
					src={panels[0].image}
					alt={panels[0].imageAlt}
					class="absolute inset-0 h-full w-full object-cover"
					style="z-index: 2; opacity: 1"
					loading="eager"
					decoding="async"
				/>
				<img
					data-just-ask-layer="1"
					src={panels[0].image}
					alt=""
					class="absolute inset-0 h-full w-full object-cover"
					style="z-index: 1; opacity: 0"
					loading="eager"
					decoding="async"
					aria-hidden="true"
				/>
				<div
					class="pointer-events-none absolute bottom-3 right-3 z-20 origin-bottom-right scale-[0.52] rounded-full bg-white/85 p-1.5 shadow-md ring-1 ring-slate-900/10 backdrop-blur-sm md:bottom-4 md:right-4 md:scale-[0.64]"
					role="progressbar"
					aria-valuemin="0"
					aria-valuemax="100"
					aria-valuenow="0"
					aria-label="Time until the next image"
					data-just-ask-progress
				>
					<svg
						class="size-11 -rotate-90"
						width="44"
						height="44"
						viewBox="0 0 40 40"
						aria-hidden="true"
					>
						<circle
							cx="20"
							cy="20"
							r="16"
							fill="none"
							stroke="#e2e8f0"
							stroke-width="3"
						/>
						<circle
							data-just-ask-progress-ring
							cx="20"
							cy="20"
							r="16"
							fill="none"
							stroke="#059669"
							stroke-width="3"
							stroke-linecap="round"
						/>
					</svg>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	import { animate } from "motion";

	const ROTATE_MS = 5000;

	type Panel = {
		title: string;
		body: string;
		image: string;
		imageAlt: string;
	};

	let rafId: number | undefined;
	let interactionAbort: AbortController | undefined;
	let resizeObserver: ResizeObserver | undefined;

	function cancelProgressLoop() {
		if (rafId !== undefined) {
			cancelAnimationFrame(rafId);
			rafId = undefined;
		}
	}

	function stopTimersAndListeners() {
		cancelProgressLoop();
		resizeObserver?.disconnect();
		resizeObserver = undefined;
		interactionAbort?.abort();
		interactionAbort = undefined;
	}

	function initJustAskKlya() {
		const root = document.querySelector<HTMLElement>("[data-just-ask-klya]");
		if (!root) return;

		stopTimersAndListeners();
		interactionAbort = new AbortController();
		const { signal } = interactionAbort;

		const items = root.querySelectorAll<HTMLButtonElement>("[data-just-ask-item]");
		const layer0 = root.querySelector<HTMLImageElement>('[data-just-ask-layer="0"]');
		const layer1 = root.querySelector<HTMLImageElement>('[data-just-ask-layer="1"]');
		const progressBar = root.querySelector<HTMLElement>("[data-just-ask-progress]");
		const progressRing = root.querySelector<SVGCircleElement>("[data-just-ask-progress-ring]");
		if (!items.length || !layer0 || !layer1 || !progressBar || !progressRing) return;
		const layers = [layer0, layer1] as const;

		const RING_R = 16;
		const RING_LEN = 2 * Math.PI * RING_R;

		const raw = root.dataset.panelsJson;
		if (!raw) return;

		let panels: Panel[];
		try {
			panels = JSON.parse(raw) as Panel[];
		} catch {
			return;
		}

		let active = 0;
		let cycleStart = Date.now();
		let hasIndicatorPositioned = false;
		let imageSwapGen = 0;
		let visibleLayer: 0 | 1 = 0;

		function urlsMatch(a: string, b: string) {
			try {
				return new URL(a, window.location.href).href === new URL(b, window.location.href).href;
			} catch {
				return a === b;
			}
		}

		const itemsContainer = root.querySelector<HTMLElement>("[data-just-ask-items]");
		const indicatorEl = root.querySelector<HTMLElement>("[data-just-ask-indicator]");
		if (!itemsContainer || !indicatorEl) return;

		function applyClasses() {
			items.forEach((btn, i) => {
				const on = i === active;
				btn.classList.toggle("opacity-50", !on);
				btn.classList.toggle("opacity-100", on);
				btn.setAttribute("aria-current", on ? "true" : "false");
			});
		}

		function updateIndicator(opts?: { instant?: boolean }) {
			const btn = items[active];
			if (!btn) return;

			const top = btn.offsetTop;
			const height = btn.offsetHeight;

			const instant = opts?.instant === true || !hasIndicatorPositioned;

			animate(
				indicatorEl,
				{ top: `${top}px`, height: `${height}px` },
				instant ? { duration: 0 } : { duration: 0.45, ease: [0.22, 1, 0.36, 1] },
			);

			hasIndicatorPositioned = true;
		}

		function setImage() {
			const p = panels[active];
			if (!p) return;

			const showing = layers[visibleLayer];
			if (urlsMatch(showing.src, p.image) && showing.alt === p.imageAlt) {
				return;
			}

			const gen = ++imageSwapGen;
			const incoming = layers[1 - visibleLayer];

			const runCrossfade = () => {
				if (gen !== imageSwapGen) return;

				const out = layers[visibleLayer];
				const inc = layers[1 - visibleLayer];

				inc.style.zIndex = "3";
				out.style.zIndex = "2";
				inc.style.opacity = "0";

				void Promise.all([
					Promise.resolve(
						animate(out, { opacity: 0 }, { duration: 0.4, ease: [0.4, 0, 0.2, 1] }),
					),
					Promise.resolve(
						animate(inc, { opacity: 1 }, { duration: 0.4, ease: [0.22, 1, 0.36, 1] }),
					),
				]).then(() => {
					if (gen !== imageSwapGen) return;
					visibleLayer = (1 - visibleLayer) as 0 | 1;
					out.style.opacity = "0";
					out.style.zIndex = "1";
					out.setAttribute("aria-hidden", "true");
					inc.style.zIndex = "2";
					inc.removeAttribute("aria-hidden");
					out.alt = "";
				});
			};

			incoming.onload = () => {
				if (gen !== imageSwapGen) return;
				runCrossfade();
			};
			incoming.onerror = () => {
				if (gen !== imageSwapGen) return;
			};

			incoming.alt = p.imageAlt;
			incoming.src = p.image;

			if (incoming.complete) {
				incoming.onload = null;
				runCrossfade();
			}
		}

		function goTo(index: number) {
			const next = ((index % panels.length) + panels.length) % panels.length;
			if (next === active) return;
			active = next;
			applyClasses();
			setImage();
			updateIndicator();
		}

		function resetCycle() {
			cycleStart = Date.now();
		}

		function tick() {
			goTo(active + 1);
			resetCycle();
		}

		function updateProgressUi(elapsed: number) {
			const ring = progressRing;
			const bar = progressBar;
			if (!ring || !bar) return;

			const p = Math.min(1, Math.max(0, elapsed / ROTATE_MS));
			ring.style.strokeDasharray = `${RING_LEN}`;
			ring.style.strokeDashoffset = `${RING_LEN * (1 - p)}`;
			const pct = Math.round(p * 100);
			bar.setAttribute("aria-valuenow", String(pct));
		}

		function progressLoop() {
			const elapsed = Date.now() - cycleStart;
			updateProgressUi(elapsed);

			if (elapsed >= ROTATE_MS) {
				tick();
			}

			rafId = requestAnimationFrame(progressLoop);
		}

		/** `resumeElapsed` = continue the same cycle (e.g. after tab focus). Omit to start a fresh 5s. */
		function startProgressLoop(resumeElapsed?: number) {
			cancelProgressLoop();
			if (resumeElapsed !== undefined) {
				cycleStart = Date.now() - Math.min(resumeElapsed, ROTATE_MS);
			} else {
				resetCycle();
			}
			rafId = requestAnimationFrame(progressLoop);
		}

		let elapsedBeforeHidden = 0;
		document.addEventListener(
			"visibilitychange",
			() => {
				if (document.hidden) {
					elapsedBeforeHidden = Date.now() - cycleStart;
					cancelProgressLoop();
				} else {
					startProgressLoop(elapsedBeforeHidden);
				}
			},
			{ signal },
		);

		items.forEach((btn) => {
			btn.addEventListener(
				"click",
				() => {
					const idx = Number(btn.dataset.index);
					if (Number.isNaN(idx)) return;
					goTo(idx);
					startProgressLoop();
				},
				{ signal },
			);
		});

		resizeObserver = new ResizeObserver(() => {
			updateIndicator({ instant: true });
		});
		resizeObserver.observe(itemsContainer);

		applyClasses();
		requestAnimationFrame(() => {
			updateIndicator();
		});
		startProgressLoop();
	}

	initJustAskKlya();
	document.addEventListener("astro:page-load", initJustAskKlya);
</script>
