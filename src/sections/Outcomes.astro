---
const withoutItems = [
	"Decisiones tomadas desde la intuición y la memoria",
	"Problemas detectados cuando ya es tarde",
	"Talento que se va sin entender por qué",
	'El manager carga solo con el riesgo organizativo',
];

const withItems = [
	"Decisiones respaldadas por señales claras y trazables",
	"Riesgos visibles semanas antes de que escalen",
	"Visibilidad para retener y desarrollar talento interno",
	'El sistema estructura lo que antes vivía solo en conversaciones',
];
---

<section class="w-full py-8 md:py-16" aria-labelledby="outcomes-heading">
	<div class="mx-auto max-w-7xl px-4">
		<div class="flex flex-col items-center justify-center gap-2 text-center">
			<p class="text-sm font-medium text-emerald-600">Outcomes</p>
			<h2 id="outcomes-heading" class="text-3xl text-slate-900 md:text-4xl">
				Deja de reaccionar. Empieza a decidir.
			</h2>
		</div>

		<div
			class="mx-auto mt-12 flex w-full max-w-7xl flex-col gap-5 md:flex-row"
		>
			<div
				class="flex min-w-0 flex-1 flex-col gap-8 rounded-2xl bg-slate-50 p-8"
			>
				<h3 class="text-2xl font-medium text-slate-900">Sin Talio</h3>
				<ul class="flex flex-col gap-5">
					{
						withoutItems.map((text) => (
							<li class="flex gap-3">
								<span class="mt-0.5 shrink-0 text-red-500" aria-hidden="true">
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="24"
										height="24"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										class="size-6"
									>
										<circle cx="12" cy="12" r="10" />
										<path d="m15 9-6 6" />
										<path d="m9 9 6 6" />
									</svg>
								</span>
								<span class="text-xl font-normal text-slate-500">{text}</span>
							</li>
						))
					}
				</ul>
			</div>

			<div
				class="flex min-w-0 flex-1 flex-col gap-8 rounded-2xl bg-slate-50 p-8"
			>
				<h3 class="text-2xl font-medium text-slate-900">Con Talio</h3>
				<ul class="flex flex-col gap-5">
					{
						withItems.map((text) => (
							<li class="flex gap-3">
								<span class="mt-0.5 shrink-0 text-green-600" aria-hidden="true">
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="24"
										height="24"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										class="size-6"
									>
										<circle cx="12" cy="12" r="10" />
										<path d="m9 12 2 2 4-4" />
									</svg>
								</span>
								<span class="text-xl font-normal text-slate-800">{text}</span>
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</div>
</section>
