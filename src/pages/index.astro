---
import Layout from "../layouts/Layout.astro";
import ComoFunciona from "../sections/ComoFunciona.astro";
import JustAskKlya from "../sections/JustAskKlya.astro";
import Outcomes from "../sections/Outcomes.astro";
import heroImage from "../assets/images/Talio-hero.png";
---

<Layout>
	<div>
		<section class="flex flex-col items-center justify-center gap-8 py-12 md:gap-20 md:py-20">
			<div class="flex flex-col items-center justify-center gap-8 md:gap-10">
				<div class="flex flex-col items-center justify-center gap-6 md:gap-8 leading-none">
					<h1 class="text-balance text-center text-4xl leading-none text-slate-900 sm:text-5xl md:text-6xl">
						Tu equipo evoluciona. <br class="hidden md:inline" /> Tus decisiones también deberían.
					</h1>
					<p class="max-w-2xl text-center text-lg text-slate-500 md:text-xl">
						Talio convierte las conversaciones, señales y el día a día de tu equipo
						<br class="hidden md:inline" />
						en información estructurada para tomar mejores decisiones de talento.
					</p>
				</div>
				<a
					href="mailto:hello@acalvet.com"
					class="inline-flex rounded-full bg-emerald-600 px-8 py-4 text-base font-medium text-white hover:bg-emerald-500"
				>
					Solicitar demo
				</a>
			</div>
			<div
				class="mx-auto w-full min-w-0 max-w-full translate-y-[10px] opacity-0 md:max-w-5xl"
				data-motion-hero
			>
				<img
					src={heroImage.src}
					width={heroImage.width}
					height={heroImage.height}
					alt="Talio"
					class="h-auto w-full rounded-lg md:rounded-2xl"
					loading="eager"
					decoding="async"
					fetchpriority="high"
				/>
			</div>
		</section>
		<section
			id="introduction"
			class="mx-auto grid w-full max-w-7xl grid-cols-1 items-start gap-8 px-4 py-12 md:grid-cols-2 md:gap-10 md:py-16"
		>
			<h2 class="text-left text-3xl leading-tight text-slate-900 md:text-4xl">
				Conoce a tu equipo antes de tomar <br class="hidden md:inline" /> la siguiente decisión.
			</h2>
			<div class="flex flex-col items-start justify-center gap-4">
				<p class="text-lg leading-relaxed text-slate-500 md:text-xl">
					Los managers toman decisiones críticas sobre personas cada semana. Raramente con toda la información.
				</p>
				<p class="text-lg leading-relaxed text-slate-800 md:text-xl">
					Talio estructura esa información y la hace visible antes de que tengas que actuar.
				</p>
			</div>
		</section>
		<ComoFunciona />
		<JustAskKlya />
		<Outcomes />
	</div>
</Layout>
