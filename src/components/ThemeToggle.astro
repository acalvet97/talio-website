<button
	type="button"
	data-theme-toggle
	class="rounded-full border border-slate-300 p-2 text-sm text-slate-800 transition hover:border-slate-400 dark:border-slate-600 dark:text-slate-100 dark:hover:border-slate-400"
	aria-label="Toggle color theme"
>
	<span class="dark:hidden" aria-hidden="true">Dark</span>
	<span class="hidden dark:inline" aria-hidden="true">Light</span>
</button>

<script>
	document.querySelectorAll("[data-theme-toggle]").forEach((btn) => {
		btn.addEventListener("click", () => {
			document.documentElement.classList.toggle("dark");
		});
	});
</script>
