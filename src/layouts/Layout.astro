---
import "../styles/global.css";
import Header from "../sections/Header.astro";
import PreFooterCta from "../sections/PreFooterCta.astro";
import Footer from "../sections/Footer.astro";

interface Props {
	title?: string;
}

const { title = "Klira" } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/Klira-favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-dvh bg-white text-zinc-800 antialiased">
		<div class="flex min-h-dvh flex-col">
			<Header />
			<main class="flex w-full flex-1 flex-col items-stretch justify-center px-4 md:px-8">
				<slot />
			</main>
			<PreFooterCta />
			<Footer />
		</div>
		<script>
			import { animate } from "motion";

			const el = document.querySelector("[data-motion-hero]");
			if (el) {
				animate(
					el,
					{ opacity: [0, 1], y: [12, 0] },
					{ duration: 0.55, ease: [0.22, 1, 0.36, 1] },
				);
			}
		</script>
	</body>
</html>
